{
  "name": "one-for-all-mcfallout-bot",
  "version": "1.4.0",
  "description": "minecraft bot for mcfallout server",
  "main": "index.js",
  "scripts": {
    "postinstall": "patch-package",
    "test": "echo \"Error: no test specified\" && exit 1",
    "bw": "node scripts/prune-mc-data.js && node scripts/build-win.js",
    "bl": "node scripts/prune-mc-data.js && pkg -t node22-linux-x64 --no-bytecode --public --public-packages \"*\" index.js -o ofal/ofa_linux",
    "bbw": "node scripts/build-win.js --compress",
    "bbl": "pkg index.js -t node22-linux-x64 --no-bytecode --public --public-packages \"*\" --compress GZip -o release/ofa_linux"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JKLoveUU/One-For-All-Minecraft-Bot.git"
  },
  "files": [
    "index.js",
    "./bots",
    "./bots/generalbot.js",
    "./bots/raidbot.js",
    "./defaults",
    "./lib",
    "./src"
  ],
  "pkg": {
    "assets": [
      "defaults/**/*",
      "node_modules/neo-blessed/usr/**/*"
    ],
    "scripts": [
      "src/modules/botmanager.js",
      "bots/generalbot.js",
      "index.js",
      "bots/lib/*.js",
      "bots/*.js",
      "lib/**/*.js",
      "lib/*.js",
      "src/**/*.js",
      "src/*.js",
      "node_modules/neo-blessed/lib/widgets/*.js",
      "node_modules/@discordjs/rest/dist/**/*.js"
    ]
  },
  "author": "JKLove",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JKLoveUU/One-For-All-Minecraft-Bot/issues"
  },
  "homepage": "https://github.com/JKLoveUU/One-For-All-Minecraft-Bot#readme",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "axios": "^1.16.1",
    "undici": "^8.3.0",
    "uuid": "^11.1.1"
  },
  "dependencies": {
    "@discordjs/builders": "^1.14.1",
    "@discordjs/rest": "2.6.1",
    "@types/node": "^25.8.0",
    "axios": "^1.16.1",
    "chinese-numbers-to-arabic": "^2.0.0",
    "discord-api-types": "^0.38.47",
    "discord.js": "^14.26.4",
    "fs": "^0.0.1-security",
    "js-binary": "^1.2.0",
    "minecraft-data": "^3.110.2",
    "minecraft-protocol": "^1.66.2",
    "mineflayer": "^4.37.1",
    "moment": "^2.30.1",
    "neo-blessed": "^0.2.0",
    "p-timeout": "^7.0.1",
    "prismarine-chat": "^1.13.0",
    "prismarine-item": "^1.18.0",
    "prismarine-nbt": "^2.8.0",
    "prismarine-recipe": "^1.5.0",
    "prismarine-registry": "^1.12.0",
    "prismarine-schematic": "^1.3.0",
    "silly-datetime": "^0.1.2",
    "toml": "^4.1.1",
    "toml-require": "^1.2.0",
    "vec3": "^0.2.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0",
    "patch-package": "^8.0.1"
  }
}
